{
  "dashboard": {
    "title": "RAG System Metrics",
    "panels": [
      {
        "id": 1,
        "title": "Query Rate (Queries/Second)",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(rag_queries_total[1m])",
            "legendFormat": "Queries/sec"
          }
        ]
      },
      {
        "id": 2,
        "title": "Response Latency (P50, P95, P99)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(rag_response_time_bucket[1m]))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(rag_response_time_bucket[1m]))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(rag_response_time_bucket[1m]))",
            "legendFormat": "P99"
          }
        ]
      },
      {
        "id": 3,
        "title": "Token Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "rag_tokens_used",
            "legendFormat": "Tokens Used"
          }
        ]
      },
      {
        "id": 4,
        "title": "Error Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_count{status=\"5xx\"}[1m])",
            "legendFormat": "Errors/sec"
          }
        ]
      }
    ]
  }
}
